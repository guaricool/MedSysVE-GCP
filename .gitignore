# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# superpowers
.superpowers/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# uploaded files (runtime assets, not source)
/public/uploads/
!/public/uploads/marketing/

# playwright QA session artifacts
.playwright-mcp/
/test-results/
/playwright-report/

# graphify index output (regenerated by `graphify`)
/graphify-out/

# Generated encryption keys (NEVER commit)
.env.keys
*.key

.env.stripe.local
.env.coolify.local

# Manual authoring working files (regenerated by render-manual.js)
# Track index.html (entry point) and final PDF, ignore the per-section HTML sources
content/manual/parte-*.html

# Test-only JWT minting scripts (hardcoded test user IDs + AUTH_SECRET).
# Regenerate locally if needed: see docs/SMOKE_TESTS.md (TBD).
scripts/smoke/mint-jwt-*.mjs

# MSMTP configuration template
config/msmtprc
