/// Comprehensive PHI-access audit trail. Every read/write of clinical data
/// should produce a row here. Distinct from AuditLog (which captures only
/// high-severity events like signed consultations or config changes).
///
/// LOPDP (Venezuela, Ley Orgánica de Protección de Datos Personales) Art. 19
/// requires technical safeguards for personal data — this audit log is one
/// such safeguard. Retention policy: see docs/DATA_RETENTION.md.
model AuditEvent {
  id              String    @id @default(cuid())
  workspaceId     String
  /// userId of the actor (doctor, staff). Null for unauthenticated events.
  actorId         String?
  actorRole       String?
  /// What was done. Use one of the AuditAction enum values (string for forward-compat).
  action          String
  /// Resource type accessed, e.g. "Encounter", "PatientRegistration", "Prescription".
  resourceType    String
  /// Resource ID (cuid). Use cuid() not patient.cedula for privacy.
  resourceId      String?
  /// If the resource is patient-scoped, the patientRegistrationId for fast lookup.
  patientId       String?
  /// Outcome of the access: "ALLOWED" or "DENIED".
  outcome         String    @default("ALLOWED")
  /// Reason for denial (if applicable). Empty string when allowed.
  denialReason    String?
  /// Originating IP (truncated to /24 for IPv4, /48 for IPv6 in app).
  ip              String?
  /// Browser/client user agent.
  userAgent       String?
  /// Method of access: "UI", "API", "PDF", "EXPORT", "PORTAL".
  channel         String    @default("UI")
  /// Free-form JSON for additional context (e.g., which PDF was downloaded).
  metadata        Json?
  /// Encrypted (AES-256-GCM) JSON-as-text for additional context.
  /// Preferred for new writes; readers fall back to `metadata` (plaintext) when NULL.
  metadataCifrado String?   @db.Text
  createdAt       DateTime  @default(now())
  /// Set by scripts/archive-old-audit-events.ts when the row exceeds the
  /// retention window (default 5 years, per docs/DATA_RETENTION.md).
  /// Archived rows are kept indefinitely for compliance but excluded from
  /// default app queries. Use the helpers in lib/audit.ts:
  ///   - listActiveAuditEvents(workspaceId, opts)        [default: archivedAt IS NULL]
  ///   - getActiveAuditEvent(id)                          [default: archivedAt IS NULL]
  ///   - countActiveAuditEvents(workspaceId, opts)        [default: archivedAt IS NULL]
  /// For compliance/LOPDP reporting queries that intentionally need
  /// archived rows, pass includeArchived: true.
  archivedAt      DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([actorId, createdAt])
  @@index([patientId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
  @@index([archivedAt, createdAt])
}

// ---------------------------------------------------------------------------
// FASE 35 — Marco Legal (LOPDP / Términos / Cookies)
// ---------------------------------------------------------------------------

/// A versioned, published version of a legal document (ToS, Privacy, Cookies).
/// Content lives in `content/legal/*.md`; this row is the audit trail of what
/// was published, when, and which hash (sha256 of the markdown) was bound.
model LegalVersion {
  id          String   @id @default(cuid())
  slug        String // "terminos" | "privacidad" | "cookies" | "lopdp-consentimiento"
  version     String // e.g. "1.0.0"
  title       String
  /// sha256 of the markdown source — detects content drift vs the file on disk.
  contentHash String
  effectiveAt DateTime
  publishedBy String?
  notes       String?
  createdAt   DateTime @default(now())

  acceptances ConsentAcceptance[]

  @@unique([slug, version])
  @@index([slug, effectiveAt])
}

/// Every time a doctor clicks "Acepto Términos / Privacidad / Cookies" we
/// write a row here. Tamper-evident (workspaceId-scoped via Doctor).
///
/// LOPDP Art. 25 (consentimiento expreso) and Art. 32 (prueba del consentimiento).
model ConsentAcceptance {
  id             String   @id @default(cuid())
  doctorId       String
  legalVersionId String
  /// Slug of the legal doc that was accepted, denormalised for fast queries.
  slug           String
  version        String
  /// Truncated client IP (matches lib/log-sanitizer.ts convention).
  ip             String?
  userAgent      String?  @db.Text
  /// True when the user explicitly checked the acceptance box. False when
  /// the acceptance is implicit (e.g. legacy users grandfathered in).
  explicit       Boolean  @default(true)
  createdAt      DateTime @default(now())

  doctor       Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  legalVersion LegalVersion @relation(fields: [legalVersionId], references: [id], onDelete: Restrict)

  @@index([doctorId, createdAt])
  @@index([legalVersionId])
  @@index([slug, version])
}

/// A patient (or their doctor on their behalf) requests a copy of their
/// personal data. LOPDP Art. 60 — derecho de acceso. Workflow:
///   REQUESTED → PREPARING → READY (download URL) → DELIVERED → CLOSED.
/// Download links expire after 30 days.
model DataExportRequest {
  id                String    @id @default(cuid())
  doctorId          String // who requested (patient via portal OR doctor)
  patientCedulaHMAC String? // HMAC of the target patient cedula (searchable encryption)
  scope             String // "PATIENT_FULL" | "DOCTOR_FULL"
  status            String    @default("REQUESTED")
  downloadToken     String?   @unique
  downloadUrl       String?   @db.Text
  expiresAt         DateTime?
  requestedAt       DateTime  @default(now())
  readyAt           DateTime?
  downloadedAt      DateTime?
  closedAt          DateTime?
  ip                String?
  notes             String?   @db.Text

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, requestedAt])
  @@index([status, expiresAt])
}

/// LOPDP Art. 61 — derecho de cancelación. Soft-delete: we never physically
/// destroy clinical rows (legal retention + audit immutability), but we
/// tombstone the patient (numeroIdentificacion and nombre become "ANONIMIZADO-NNN"),
/// PHI fields are wiped, and the patient is marked `deletedAt`. The audit
/// trail is preserved indefinitely.
model DataDeletionRequest {
  id                String    @id @default(cuid())
  doctorId          String
  patientCedulaHMAC String?
  status            String    @default("REQUESTED")
  reason            String?   @db.Text
  approvedAt        DateTime?
  appliedAt         DateTime?
  /// Tombstone id assigned to the anonymised patient for traceability.
  tombstoneId       String?
  ip                String?
  requestedAt       DateTime  @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, requestedAt])
  @@index([status])
}

/// LOPDP Art. 64 + buena práctica: register security incidents so we can
/// produce a breach-notification template (with affected users, scope,
/// remediation) within the 72-hour window. Not auto-detected — this is
/// the admin's ledger for incidents that did happen.
model BreachIncident {
  id                 String    @id @default(cuid())
  slug               String    @unique
  title              String
  severity           String // "LOW" | "MEDIUM" | "HIGH" | "CRITICAL"
  status             String    @default("INVESTIGATING") // INVESTIGATING | CONTAINED | NOTIFIED | CLOSED
  detectedAt         DateTime
  containedAt        DateTime?
  notifiedAt         DateTime?
  closedAt           DateTime?
  affectedUsers      Int       @default(0)
  affectedWorkspaces Int       @default(0)
  dataCategories     String[] // ["PHI", "PII", "AUTH", "BILLING"]
  description        String    @db.Text
  rootCause          String?   @db.Text
  remediation        String?   @db.Text
  reportedBy         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status, detectedAt])
  @@index([severity, detectedAt])
}

// ---------------------------------------------------------------------------
// Email OTP (one-time codes for registration verification & password reset)
// ---------------------------------------------------------------------------

/// Purpose of a one-time code sent via email.
/// - EMAIL_VERIFY: required to complete new-doctor registration. Row is created
///   BEFORE the doctor exists, so no FK to Doctor.
/// - PASSWORD_RESET: sent to an existing doctor's email. Verified token is
///   exchanged for a short-lived reset credential used to change the password.
enum OtpPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
}

/// A 6-digit one-time code sent by email. Stored as SHA-256 hash, never
/// plaintext. Rate-limited at the API layer (5 requests/hour per email,
/// 10 verification attempts per code). Lifetime: 10 minutes (EMAIL_VERIFY)
/// or 15 minutes (PASSWORD_RESET).
///
/// After successful verification we mark `consumedAt` so the row cannot be
/// reused. The caller receives a one-time "verified token" (HMAC of the row
/// id + secret) to authorize the next step (registration or password change);
/// that token expires in 15 min independently of the OTP lifetime.
model EmailOtp {
  id         String     @id @default(cuid())
  /// Lowercased email address. Indexed for the lookup in `requestOtp` and
  /// `verifyOtp` procedures.
  email      String
  /// SHA-256 of the 6-digit code (plaintext code is sent to the user, never
  /// stored). Compared with `crypto.timingSafeEqual` to defeat timing attacks.
  codeHash   String
  purpose    OtpPurpose
  /// Brute-force protection: incremented on every failed `verifyOtp` call.
  /// Verification is rejected after 10 failed attempts even if the code is
  /// later correct (require new request).
  attempts   Int        @default(0)
  /// Set on successful verification. After this the row is dead and any
  /// further `verifyOtp` with the same code returns `consumed`.
  consumedAt DateTime?
  /// Hard expiry. Verification is rejected after this moment. Index supports
  /// a periodic cleanup job that deletes rows older than 24h.
  expiresAt  DateTime
  /// Truncated client IP (matches lib/log-sanitizer.ts convention).
  ip         String?
  userAgent  String?    @db.Text
  createdAt  DateTime   @default(now())

  @@index([email, purpose, expiresAt])
  @@index([expiresAt])
}

// Audit S10 (2026-07-07): per-doctor feature-flag override. Closes audit #15.
//
// FEATURE_FLAGS.md §7 previously said per-doctor override was "out of scope;
// use experimental flags". This model + a small admin-only tRPC router
// brings the override capability into production. Use case: a specific
// doctor reports a hallucination issue and we want to disable AI features
// for them immediately WITHOUT a code deploy AND WITHOUT touching the
// global flag (other doctors keep working).
//
// Decision tree (see lib/feature-flags.ts:isAIFeatureEnabled):
//   1. Master `ai.enabled` switch off → false (no exception).
//   2. Per-doctor row exists and not expired → use its `enabled` value.
//   3. Otherwise fall back to rollout percent (existing logic).
//
// TTL: `expiresAt` is a safety net — admin can set a temporary 24h override
// during a hotfix and not have to remember to clear it. The cron-friendly
// index supports a future cleanup job.
model DoctorFeatureOverride {
  id          String    @id @default(cuid())
  /// The doctor whose AI access we're controlling.
  doctorId    String
  /// The flag being overridden. Today: "ai" (the only tier we expose per-doctor).
  /// Future keys could be e.g. "experimental.newDashboard".
  flagKey     String
  /// Whether AI features are ON for this doctor. False = the master switch
  /// and rollout percent don't apply; doctor has AI disabled for them
  /// until the override is cleared or expires.
  enabled     Boolean
  /// Why this override exists. Required when disabling, optional when enabling.
  reason      String?
  /// Set NULL for a permanent override. Past this moment, the row is
  /// ignored by `isAIFeatureEnabled` and the global rollout applies.
  expiresAt   DateTime?
  /// Admin who set this. Audit trail (also recorded in AuditEvent on every
  /// set/clear mutation).
  setByUserId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  doctor Doctor @relation("OverrideDoctor", fields: [doctorId], references: [id], onDelete: Cascade)
  setBy  Doctor @relation("OverrideSetBy", fields: [setByUserId], references: [id], onDelete: NoAction)

  @@unique([doctorId, flagKey])
  @@index([flagKey])
  @@index([expiresAt])
}

/// Per-doctor preferences for the customizable medical report (informe).
///
/// Source of truth for which sections appear in the AI-generated draft, plus
/// the doctor's standing instructions per section (e.g. "in the exam
/// section, always lead with cardiovascular"). Doctors configure this once
/// in their profile and 99% of their informes use the result directly. For
/// a one-off special case the doctor can override at consulta time, which
/// is stored on the `Document.reportOverride` JSON column.
///
/// One row per doctor (enforced by `@@unique([doctorId])`). The doctor
/// sees an empty state with sensible defaults the first time they visit
/// `/dashboard/preferencias-informe` — see `DEFAULT_REPORT_SECCIONES` in
/// `types/report.ts` for the default section set.
model DoctorReportPreferences {
  id                   String   @id @default(cuid())
  doctorId             String   @unique
  /// Map from ReportSectionKey (motivoConsulta, historiaClinica, …) to
  /// boolean. Sections not in the map default to TRUE on first render
  /// (the doctor toggles them OFF). Sections explicitly FALSE are
  /// excluded from the AI prompt.
  ///
  /// Shape: { motivoConsulta: true, historiaClinica: true,
  ///           signosVitales: false, examenFisico: true, … }
  secciones            Json
  /// Default instructions the doctor wants the AI to follow per section
  /// on every informe. Free-text, optional. The doctor can override
  /// per-consulta via Document.reportOverride.instrucciones.
  ///
  /// Shape: { examenFisico: "En pacientes quirúrgicos, incluir siempre
  ///            descripción del sitio quirúrgico", … }
  instruccionesDefault Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model ExpressOrder {
  id               String    @id @default(cuid())
  tipo             String // "RECETA" | "LABORATORIO" | "IMAGEN"
  pacienteNombre   String
  pacienteApellido String
  pacienteCedula   String?
  pacienteEdad     Int
  pacienteSexo     String?
  items            Json // List of items (medications or studies)
  diagnosticos     String? // Opcional
  indicaciones     String? // Opcional
  createdAt        DateTime  @default(now())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model MarketingPost {
  id          String   @id @default(cuid())
  imageUrl    String   @db.Text
  caption     String   @db.Text
  hashtags    String   @db.Text
  style       String // "hyperrealistic", "cartoon", "screenshot"
  status      String // "PUBLISHED", "FAILED"
  igMediaId   String?
  publishedAt DateTime @default(now())
}

model MarketingMessage {
  id           String   @id @default(cuid())
  telefono     String
  nombrePerfil String?
  texto        String   @db.Text
  direccion    String // "INBOUND" o "OUTBOUND"
  leido        Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// FASE PORTAL MARKETPLACE
// ---------------------------------------------------------------------------

enum VerificationMethod {
  WHATSAPP
  EMAIL
}

model PortalUser {
  id           String  @id @default(cuid())
  email        String? @unique
  telefono     String? @unique
  passwordHash String
  isVerified   Boolean @default(false)

  patientProfile GlobalPatientProfile?
  intents        VerificationIntent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalPatientProfile {
  id           String     @id @default(cuid())
  portalUserId String     @unique
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)

  tipoIdentificacion   IdentificationType?
  numeroIdentificacion String?
  nombre               String
  apellido             String
  fechaNacimiento      DateTime?
  sexo                 SexoType?
  grupoSanguineo       String?

  // Opcionales para importación (Global EHR)
  alergias     String[] @default([])
  vacunas      String[] @default([])
  seguros      String[] @default([])
  antecedentes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationIntent {
  id               String             @id @default(cuid())
  codigo           String             @unique // Ej. "VERIFICAR-1234"
  otp              String? // Generado post-webhook
  method           VerificationMethod
  expiresAt        DateTime
  portalUserId     String?
  portalUser       PortalUser?        @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  registrationData String?            // JSON string containing registration details if user is not created yet

  createdAt DateTime @default(now())
}
