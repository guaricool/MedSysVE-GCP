// ---------------------------------------------------------------------------
// FASE 2 — Núcleo Clínico
// ---------------------------------------------------------------------------

enum EncounterStatus {
  DRAFT
  SIGNED
  AMENDED
}

enum DiagnosisTipo {
  PRINCIPAL
  SECUNDARIO
}

enum DocumentTipo {
  INFORME
  REPOSO
  REFERIDO
  CERTIFICADO
  RECETA
}

model Encounter {
  id                    String @id @default(cuid())
  workspaceId           String
  patientRegistrationId String
  doctorId              String

  appointmentId String?

  motivoCifrado          String? @db.Text
  /// HMAC-SHA-256 index for searchable motivo (see lib/field-crypto.ts).
  /// Computed at write time using FIELD_HMAC_KEY.
  motivoHmac             String?
  /// Encrypted with AES-256-GCM (field-level encryption).
  /// Plaintext is NEVER written to disk.
  historiaClinicaCifrada String? @db.Text
  planCifrado            String? @db.Text
  /// Legacy plaintext fields kept for migration. Will be removed after
  /// migration runs in production. Until then, routers write to *Cifrada only.
  historiaClinica        String? @db.Text
  plan                   String? @db.Text
  vitales                Json?
  examenFisico           Json?
  reportOverride         Json?
  datosEspecialidad      Json?

  status        EncounterStatus @default(DRAFT)
  signedAt      DateTime?
  signedBy      String?
  /// HMAC-SHA-256 binding {encounterId, signedBy, signedAt, content}.
  /// Computed at sign time using FIELD_ENCRYPTION_KEY. Tampering with
  /// any of these fields invalidates the signature. Stored alongside
  /// the encounter so post-hoc integrity checks don't need the plaintext.
  signatureHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Audit S9 (2026-07-07): optimistic locking counter. Incremented on every
  /// successful update. Mutations that pass `version` check it against the
  /// current row, and the updateMany returns 0 rows on mismatch → router
  /// throws TRPCError CONFLICT so callers can re-fetch + re-apply. Without
  /// this, two doctors (or a doctor + auto-save debounce) editing the same
  /// encounter concurrently would last-write-wins and silently drop edits.
  /// See docs/AUDIT_BACKLOG.md #12 and server/routers/encounter.ts.
  version   Int      @default(0)

  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patientRegistration PatientRegistration @relation(fields: [patientRegistrationId], references: [id], onDelete: Cascade)
  appointment         Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  diagnoses               Diagnosis[]
  prescriptions           Prescription[]
  labOrders               LabOrder[]
  imagingOrders           ImagingOrder[]
  documents               Document[]
  invoices                Invoice[]
  labResults              LabResult[]
  consents                PatientConsent[]
  scales                  EncounterScale[]
  orlAudiometries         OrlAudiometry[]
  orlEndoscopies          OrlEndoscopyReport[]
  orlPins                 OrlDiagramPin[]
  traumaImplantes         TraumaImplante[]
  traumaAoClassifications TraumaAoClassification[]
  traumaRehabProtocols    TraumaRehabProtocol[]
  cardioEkgs              CardioEkg[]
  cardioEchos             CardioEcho[]
  cardioRiskScores        CardioRiskScore[]
  pediaGrowthPoints       PediaGrowthPoint[]
  pediaMilestones         PediaDevelopmentMilestone[]
  pediaDoseRecords        PediaDoseRecord[]
  obPrenatalControls      ObPrenatalControl[]
  gynoScreenings          GynoScreening[]
  neuroScales             NeuroScaleRecord[]
  neuroDermatomes         NeuroDermatomeMap[]
  neuroSeizures           NeuroSeizureLog[]
  endoGlycemicLogs        EndoGlycemicLog[]
  endoInsulinTitrations   EndoInsulinTitration[]
  endoThyroidNodules      EndoThyroidNodule[]
  psychMentalStates       PsychMentalStateExam[]
  psychScales             PsychScalesRecord[]
  psychMedications        PsychMedicationMonitoring[]
  dermProfiles            DermSkinProfile[]
  dermLesions             DermLesionRecord[]
  dermBiopsies            DermBiopsyRecord[]
  gastroReports           GastroEndoscopyReport[]
  gastroBleedings         GastroBleedingScale[]
  gastroIbdScores         GastroIbdScore[]
  anesthesiaPreEvals      AnesthesiaPreEval[]
  anesthesiaAirways       AnesthesiaAirwayAssessment[]
  anesthesiaIntraops      AnesthesiaIntraopRecord[]
  surgeryChecklists       SurgerySafetyChecklist[]
  surgeryReports          SurgeryOperativeReport[]
  surgeryComplications    SurgeryClavienDindo[]
  infectoAntibiograms     InfectoAntibiogram[]
  infectoRenalAdjustments InfectoRenalAdjustment[]
  infectoControls         InfectoInfectionControl[]
  internalCharlsons       InternalCharlsonIndex[]
  internalScores          InternalClinicalScores[]
  internalPolypharmacies  InternalPolypharmacyAlert[]
  pneumoSpirometries      PneumoSpirometry[]
  pneumoGinaGolds         PneumoGinaGold[]
  pneumoDyspneaCats       PneumoDyspneaCat[]
  oncoStagings            OncoTnmStaging[]
  oncoStatuses            OncoPerformanceStatus[]
  oncoChemos              OncoChemoProtocol[]
  uroIpssScores           UroIpssScore[]
  uroPsas                 UroPsaCalculator[]
  uroFlowmetries          UroUroflowmetry[]
  ophthoRefractions       OphthoRefractionVisualAcuity[]
  ophthoGlaucomas         OphthoGlaucomaRetinopathy[]
  ophthoFindings          OphthoEyeFindings[]
  rheumaJoints            RheumaJointMapper[]
  rheumaScores            RheumaActivityScores[]
  rheumaPostVirals        RheumaPostViralArthritis[]
  nephroEgfrs             NephroEgfrCalculator[]
  nephroSessions          NephroDialysisSession[]
  nephroAccesses          NephroVascularAccess[]
  emergTriages            EmergTriageAssessment[]
  emergResusCodes         EmergResusCode[]
  emergFastProtocols      EmergFastProtocol[]

  @@index([workspaceId])
  @@index([patientRegistrationId])
  @@index([doctorId])
}

model CardioEkg {
  id                    String @id @default(cuid())
  encounterId           String
  patientRegistrationId String
  workspaceId           String

  ritmo              String // Sinusal Normal, Fibrilación Auricular, Flutter, etc.
  frecuenciaCardiaca Int // bpm
  ejeQrs             Int? // Grados
  intervaloPr        Int? // ms
  duracionQrs        Int? // ms
  intervaloQtc       Int? // ms (Bazett)
  ondaP              String?
  segmentoSt         String? // Isoeléctrico, Supradesnivel, Infradesnivel
  ondaT              String? // Positiva, Invertida, Picuda
  conclusion         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encounter           Encounter           @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  patientRegistration PatientRegistration @relation(fields: [patientRegistrationId], references: [id], onDelete: Cascade)

  @@index([encounterId])
  @@index([patientRegistrationId])
  @@index([workspaceId])
}

model CardioEcho {
  id                    String @id @default(cuid())
  encounterId           String
  patientRegistrationId String
  workspaceId           String

  fevi                    Float // Fracción Eyección VI %
  metodoFevi              String? @default("Simpson Biplano")
  ddvi                    Float? // Diámetro Diastólico VI (mm)
  dsvi                    Float? // Diámetro Sistólico VI (mm)
  septum                  Float? // Grosor Septum (mm)
