enum AppointmentType {
  CONSULTA
  SEGUIMIENTO
  EMERGENCIA
  PROCEDIMIENTO
  VIDEOCONSULTA
}

enum AppointmentStatus {
  REQUESTED
  SCHEDULED
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum PaymentMethod {
  EFECTIVO_USD
  EFECTIVO_BS
  TRANSFERENCIA_BS
  ZELLE
  BINANCE_USDT
  PAGOMOVIL
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

model Appointment {
  id                    String  @id @default(cuid())
  workspaceId           String
  patientRegistrationId String?

  titulo          String?
  tipo            AppointmentType   @default(CONSULTA)
  status          AppointmentStatus @default(SCHEDULED)
  fechaHora       DateTime
  duracionMinutos Int               @default(30)
  notas           String?
  serieId         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Audit S9 (2026-07-07): optimistic locking counter. Incremented on every
  /// successful update. Mutations that pass `version` check it against the
  /// current row, and the updateMany returns 0 rows on mismatch → router
  /// throws TRPCError CONFLICT so callers can re-fetch + re-apply. Without
  /// this, two doctors (or a doctor + auto-save debounce) editing the same
  /// encounter concurrently would last-write-wins and silently drop edits.
  /// See docs/AUDIT_BACKLOG.md #12 and server/routers/encounter.ts.
  version   Int      @default(0)

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patientRegistration PatientRegistration? @relation(fields: [patientRegistrationId], references: [id], onDelete: SetNull)
  encounters          Encounter[]
  waitingEntry        WaitingEntry?

  @@index([workspaceId])
  @@index([workspaceId, fechaHora])
  @@index([patientRegistrationId])
  @@index([fechaHora])
  @@index([serieId])
}

model Invoice {
  id                    String  @id @default(cuid())
  workspaceId           String
  patientRegistrationId String
  encounterId           String?

  numero              String
  descripcion         String?
  /// Encrypted (AES-256-GCM). Preferred for new writes. Readers fall back to
  /// `descripcion` (plaintext) when this is NULL — legacy rows.
  descripcionCifrada  String?       @db.Text
  montoUsd            Decimal       @db.Decimal(10, 2)
  tasaBcv             Decimal       @db.Decimal(10, 4)
  montoBs             Decimal       @db.Decimal(14, 2)
  metodoPago          PaymentMethod @default(EFECTIVO_USD)
  status              InvoiceStatus @default(PENDING)
  pdfUrl              String?
  fechaPago           DateTime?
  insuranceProviderId String?
  montoSeguro         Decimal?      @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patientRegistration PatientRegistration @relation(fields: [patientRegistrationId], references: [id])
  encounter           Encounter?          @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  insuranceProvider   InsuranceProvider?  @relation(fields: [insuranceProviderId], references: [id])
  pagos               Pago[]
  items               InvoiceItem[]

  @@unique([workspaceId, numero])
  @@index([workspaceId])
  @@index([patientRegistrationId])
  @@index([encounterId])
}

model Pago {
  id         String        @id @default(cuid())
  invoiceId  String
  invoice    Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  monto      Decimal       @db.Decimal(10, 2)
  metodoPago PaymentMethod
  fecha      DateTime      @default(now())
  notas      String?
  createdAt  DateTime      @default(now())

  @@index([invoiceId])
}

