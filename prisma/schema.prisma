generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum StaffRole {
  SECRETARY
  ASSISTANT
  NURSE
}

enum ClinicRole {
  OWNER
  STAFF
  CONTRACTOR
}

/// Role of a non-doctor administrator who manages a Clinic's dashboard.
/// Distinct from `Doctor` and from `ClinicRole` (which is the doctor-facing
/// affiliation table).
///
/// - OWNER: the admin who registered the Clinic via /register. Cannot be
///   removed; only one OWNER per Clinic. Can add MANAGER admins, rotate the
///   invitation code, manage staff, and view billing.
/// - MANAGER: sub-admins added by the OWNER. Same dashboard access but cannot
///   remove the OWNER or other MANAGERs, and cannot delete the clinic.
enum ClinicAdminRole {
  OWNER
  MANAGER
}

enum IdentificationType {
  CEDULA_V
  CEDULA_E
  PASAPORTE
}

enum ParentRelationship {
  PADRE
  MADRE
  TUTOR_LEGAL
  OTRO
}

enum SexoType {
  MASCULINO
  FEMENINO
  OTRO
}

model Doctor {
  id                     String                    @id @default(cuid())
  cedula                 String                    @unique
  /// Encrypted (AES-256-GCM).
  cedulaCifrada          String?
  nombre                 String
  /// Encrypted (AES-256-GCM). NULL until backfill completes; readers should
  /// fall back to `nombre` (plaintext) when this is NULL for backwards compat.
  nombreCifrado          String?                   @db.Text
  apellido               String
  apellidoCifrado        String?                   @db.Text
  email                  String                    @unique
  passwordHash           String
  telefono               String?
  telefonoCifrado        String?                   @db.Text
  fotoUrl                String?
  selloUrl               String?
  especialidadPrincipal  String
  subEspecialidades      String[]                  @default([])
  bio                    String?                   @db.Text
  idiomas                String[]                  @default([])
  rif                    String?
  /// Encrypted (AES-256-GCM).
  rifCifrado             String?
  datosFiscales          Json?
  plan                   String                    @default("free")
  stripeCustomerId       String?                   @unique
  stripeSubscriptionId   String?                   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  isAdmin                Boolean                   @default(false)
  // ──── 2FA / TOTP ────
  /// Base32-encoded TOTP secret. NEVER returned to client (only used for QR enrollment).
  totpSecret             String?
  totpEnabled            Boolean                   @default(false)
  totpEnabledAt          DateTime?
  /// Last successful TOTP verify timestamp (replay protection window).
  totpLastUsed           DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  workspaces             Workspace[]
  clinicAffiliations     DoctorClinicAffiliation[]
  referidosRecibidos     Document[]                @relation("referidosRecibidos")
  backupCodes            TwoFactorBackupCode[]
  consentAcceptances     ConsentAcceptance[]
  dataExportRequests     DataExportRequest[]
  dataDeletionRequests   DataDeletionRequest[]
  usedInvitationCodes    ClinicInvitationCode[]
  featureOverrides       DoctorFeatureOverride[]   @relation("OverrideDoctor")
  featureOverridesSet    DoctorFeatureOverride[]   @relation("OverrideSetBy")
  reportPreferences      DoctorReportPreferences?

  /// Version of the legal terms the doctor has accepted. Bumped when ToS,
  /// Privacy or Cookies change. Null = never accepted. The proxy.ts or
  /// dashboard layout forces re-acceptance when this lags behind the
  /// current published LegalVersion.
  currentLegalVersion String?

  @@index([email])
}

/// One-time backup codes for 2FA recovery. Hash is bcrypt; the plaintext
/// is shown to the user ONCE during enrollment and never stored.
model TwoFactorBackupCode {
  id        String    @id @default(cuid())
  doctorId  String
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([doctorId])
}

model Clinic {
  id                     String                    @id @default(cuid())
  nombre                 String
  nombreCifrado          String?                   @db.Text
  slug                   String?                   @unique
  rif                    String?                   @unique
  razonSocial            String?
  razonSocialCifrada     String?                   @db.Text
  direccion              String?
  direccionCifrada       String?                   @db.Text
  telefono               String?
  telefonoCifrado        String?                   @db.Text
  email                  String?
  emailCifrado           String?                   @db.Text
  website                String?
  logoUrl                String?
  bannerUrl              String?
  descripcion            String?
  servicios              String[]                  @default([])
  redesSociales          Json?
  /// Estado de Venezuela donde opera la clínica (ej: "Zulia", "Miranda").
  /// Nullable para clínicas existentes pre-location-feature; el gate UI
  /// pide completar antes de habilitar referidos hacia/desde esta clínica.
  estado                 String?
  /// Ciudad principal de la clínica (ej: "Maracaibo", "Caracas"). Se matchea
  /// por igualdad (no fuzzy) en el doctor picker de referidos para evitar
  /// matches cross-estado como Maracaibo/Zulia vs Ciudad Bolívar/Bolívar.
  ciudad                 String?
  /// Códigos de invitación generados por el admin para doctores incluidos en el plan (máximo 2).
  invitationCodes        ClinicInvitationCode[]
  activa                 Boolean                   @default(true)
  plan                   String                    @default("free")
  stripeCustomerId       String?                   @unique
  stripeSubscriptionId   String?                   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  affiliations           DoctorClinicAffiliation[]
  workspaces             Workspace[]
  posts                  ClinicPost[]
  /// Non-doctor administrators who manage the clinic's dashboard.
  /// Distinct from `DoctorClinicAffiliation` (which is doctor-to-clinic).
  /// The OWNER row is created at clinic registration; additional MANAGERs
  /// can be invited later by the OWNER via the dashboard.
  clinicAdmins           ClinicAdmin[]

  @@index([estado, ciudad])
}

model ClinicInvitationCode {
  id          String   @id @default(cuid())
  clinicId    String
  code        String   @unique // e.g. CLINIC-A3F8K2
  used        Boolean  @default(false)
  usedById    String? // Doctor ID if used
  isExtraSeat Boolean  @default(false)
  createdAt   DateTime @default(now())

  clinic Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  usedBy Doctor? @relation(fields: [usedById], references: [id], onDelete: SetNull)

  @@index([clinicId])
}

/// Non-doctor user who manages a Clinic. Can add secretarias/asistentes/
/// enfermeras (Staff), rotate the invitation code, manage billing, and view
/// audit logs. Distinct from Doctor — clinic admins do NOT have a medical
/// license and never appear in the doctor referral picker.
///
/// Created when the first admin registers a Clinic via /register
/// (accountType = "clinic-admin"). Subsequent MANAGERs are invited by the
/// OWNER via the clinic dashboard.
///
/// Login uses the same NextAuth credentials provider as Doctor/Staff — the
/// authorize() callback tries Doctor → Staff → ClinicAdmin in that order.
model ClinicAdmin {
  id             String          @id @default(cuid())
  /// Login email. Unique across all ClinicAdmin rows. Lowercased on write.
  email          String          @unique
  /// bcrypt cost-12 hash of the password. Never returned to the client.
  passwordHash   String
  nombre         String
  apellido       String
  telefono       String?
  /// OWNER = primary admin who registered the clinic (one per clinic).
  /// MANAGER = sub-admin added later by the OWNER.
  role           ClinicAdminRole @default(OWNER)
  clinicId       String
  clinic         Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  activo         Boolean         @default(true)
  lastLoginAt    DateTime?
  /// Tracks consecutive failed login attempts (reset on success). Used by
  /// the auth lockout middleware.
  failedAttempts Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  /// Only one OWNER per clinic is enforced in application code (in
  /// clinicAdmin.ts — see `assertNoExistingOwner`). Prisma doesn't support
  /// partial unique constraints natively, so we don't try to express it
  /// here. Multiple MANAGERs are allowed (no DB constraint).

  @@index([clinicId])
  @@index([email])
}

model DoctorClinicAffiliation {
  id        String     @id @default(cuid())
  doctorId  String
  doctor    Doctor     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinicId  String
  clinic    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  rol       ClinicRole @default(STAFF)
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([doctorId, clinicId])
  @@index([clinicId])
}

model Workspace {
  id                           String                  @id @default(cuid())
  nombre                       String
  nombreCifrado                String?                 @db.Text
  direccion                    String?
  direccionCifrada             String?                 @db.Text
  telefono                     String?
  telefonoCifrado              String?                 @db.Text
  logoUrl                      String?
  membreteUrl                  String?
  rif                          String?
  razonSocial                  String?
  razonSocialCifrada           String?                 @db.Text
  direccionFiscal              String?
  direccionFiscalCifrada       String?                 @db.Text
  /// Estado de Venezuela donde opera este consultorio. Requerido para que el
  /// doctor aparezca en el picker de referidos de otros doctores de su zona.
  /// Nullable para workspaces existentes pre-feature.
  estado                       String?
  /// Ciudad donde opera el consultorio. Match exacto en el doctor picker.
  ciudad                       String?
  tasaBcvActual                Decimal?                @db.Decimal(10, 4)
  tasaBcvAt                    DateTime?
  recordatorioHoras            Int                     @default(24)
  recordatorioWa               Boolean                 @default(false)
  recordatorioEmail            Boolean                 @default(true)
  autoCreateHistoryOnEncounter Boolean                 @default(false)
  emailAppointmentReminders    Boolean                 @default(true)
  allowedIps                   String?
  doctorId                     String
  doctor                       Doctor                  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinicId                     String?
  clinic                       Clinic?                 @relation(fields: [clinicId], references: [id])
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  staff                        Staff[]
  patientRegs                  PatientRegistration[]
  encounters                   Encounter[]
  appointments                 Appointment[]
  invoices                     Invoice[]
  availability                 DoctorAvailability[]
  mensajes                     Mensaje[]
  alergias                     Alergia[]
  templates                    EncounterTemplate[]
  patientTags                  PatientTag[]
  availabilityExceptions       AvailabilityException[]
  documentTemplates            DocumentTemplate[]
  announcements                Announcement[]
  staffNotes                   StaffNote[]
  vaccines                     Vaccine[]
  waitingEntries               WaitingEntry[]
  notifications                Notification[]
  tasks                        Task[]
  insuranceProviders           InsuranceProvider[]
  consentTemplates             ConsentTemplate[]
  patientConsents              PatientConsent[]
  auditLogs                    AuditLog[]
  auditEvents                  AuditEvent[]
  expressOrders                ExpressOrder[]

  @@index([doctorId])
  @@index([clinicId])
  @@index([estado, ciudad])
}

model Staff {
  id            String    @id @default(cuid())
  cedula        String
  nombre        String
  apellido      String
  email         String
  pinAccesoHash String? // bcrypt hash — never store plaintext
  rol           StaffRole
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tasks         Task[]

  @@unique([cedula, workspaceId])
  @@unique([email, workspaceId])
  @@index([workspaceId])
}

model Patient {
  id                   String                @id @default(cuid())
  /// Tenant scope. Each doctor/workspace owns its own Patient records —
  /// the same person registered with two doctors exists as two Patients
  /// (one per workspace). Cross-workspace lookup by cédula uses hmacCedula
  /// at registration time to autofill personal info; clinical data NEVER
  /// crosses the workspace boundary.
  workspaceId          String?
  tipoIdentificacion   IdentificationType?
  /// Encrypted (AES-256-GCM). Plaintext is NEVER stored.
  numeroIdentificacion String?
  /// HMAC index for searchable encryption on numeroIdentificacion.
  /// Allows WHERE hmacCedula = ? queries without storing plaintext.
  hmacCedula           String?
  sinCedula            Boolean               @default(false)
  nombre               String
  /// Encrypted (AES-256-GCM) — preferred for new writes.
  nombreCifrado        String?               @db.Text
  /// HMAC index for searchable patient by nombre (case-insensitive).
  hmacNombre           String?
  apellido             String
  apellidoCifrado      String?               @db.Text
  hmacApellido         String?
  fechaNacimiento      DateTime
  sexo                 SexoType
  grupoSanguineo       String?
  direccion            String?               @db.Text
  direccionCifrada     String?               @db.Text
  telefono             String?
  codigoPais           String?               @default("+58")
  telefonoCifrado      String?               @db.Text
  hmacTelefono         String?
  email                String?
  emailCifrado         String?               @db.Text
  hmacEmail            String?
  portalPasswordHash   String?
  repCedula            String?
  repNombreCompleto    String?
  repParentesco        ParentRelationship?
  repTelefono          String?
  repEmail             String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  registrations        PatientRegistration[]

  // NOTE: a Patient is unique within a workspace by (tipoIdentificacion, numeroIdentificacion).
  // The same person registered with two different doctors exists as two Patients (one per
  // workspace). The @@unique on (tipoIdentificacion, numeroIdentificacion) was REMOVED
  // because it was the source of a tenant leak — Doctor B could see Doctor A's patient
  // row simply because both shared the same cédula in the global Patient table.
  //
  // The hmacCedula index is kept (without unique constraint) so a future autofill query
  // can search across workspaces at registration time without leaking data.
  @@unique([workspaceId, tipoIdentificacion, numeroIdentificacion])
  @@index([hmacCedula])
  @@index([hmacNombre])
  @@index([hmacApellido])
  @@index([hmacTelefono])
  @@index([hmacEmail])
}

model PatientRegistration {
  id             String             @id @default(cuid())
  idDisplay      String
  patientId      String
  patient        Patient            @relation(fields: [patientId], references: [id])
  workspaceId    String
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  notasInternas  String?
  antecedentes   Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  encounters     Encounter[]
  documents      Document[]
  appointments   Appointment[]
  invoices       Invoice[]
  labResults     LabResult[]
  mensajes       Mensaje[]
  alergias       Alergia[]
  tags           PatientTag[]
  vaccines       Vaccine[]
  waitingEntries WaitingEntry[]
  tasks          Task[]
  insurances     PatientInsurance[]
  consents       PatientConsent[]

  @@unique([workspaceId, idDisplay])
  @@unique([workspaceId, patientId])
  @@index([workspaceId])
  @@index([patientId])
}

// ---------------------------------------------------------------------------
// FASE 2 — Núcleo Clínico
// ---------------------------------------------------------------------------

enum EncounterStatus {
  DRAFT
  SIGNED
  AMENDED
}

enum DiagnosisTipo {
  PRINCIPAL
  SECUNDARIO
}

enum DocumentTipo {
  INFORME
  REPOSO
  REFERIDO
  CERTIFICADO
  RECETA
}

model Encounter {
  id                    String @id @default(cuid())
  workspaceId           String
  patientRegistrationId String
  doctorId              String

  appointmentId String?

  motivoCifrado          String? @db.Text
  /// HMAC-SHA-256 index for searchable motivo (see lib/field-crypto.ts).
  /// Computed at write time using FIELD_HMAC_KEY.
  motivoHmac             String?
  /// Encrypted with AES-256-GCM (field-level encryption).
  /// Plaintext is NEVER written to disk.
  historiaClinicaCifrada String? @db.Text
  planCifrado            String? @db.Text
  /// Legacy plaintext fields kept for migration. Will be removed after
  /// migration runs in production. Until then, routers write to *Cifrada only.
  historiaClinica        String? @db.Text
  plan                   String? @db.Text
  vitales                Json?
  examenFisico           Json?
  reportOverride         Json?
  datosEspecialidad      Json?

  status        EncounterStatus @default(DRAFT)
  signedAt      DateTime?
  signedBy      String?
  /// HMAC-SHA-256 binding {encounterId, signedBy, signedAt, content}.
  /// Computed at sign time using FIELD_ENCRYPTION_KEY. Tampering with
  /// any of these fields invalidates the signature. Stored alongside
  /// the encounter so post-hoc integrity checks don't need the plaintext.
  signatureHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Audit S9 (2026-07-07): optimistic locking counter. Incremented on every
  /// successful update. Mutations that pass `version` check it against the
  /// current row, and the updateMany returns 0 rows on mismatch → router
  /// throws TRPCError CONFLICT so callers can re-fetch + re-apply. Without
  /// this, two doctors (or a doctor + auto-save debounce) editing the same
  /// encounter concurrently would last-write-wins and silently drop edits.
  /// See docs/AUDIT_BACKLOG.md #12 and server/routers/encounter.ts.
  version   Int      @default(0)

  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patientRegistration PatientRegistration @relation(fields: [patientRegistrationId], references: [id], onDelete: Cascade)
  appointment         Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  diagnoses     Diagnosis[]
  prescriptions Prescription[]
  labOrders     LabOrder[]
  imagingOrders ImagingOrder[]
  documents     Document[]
  invoices      Invoice[]
  labResults    LabResult[]
  consents      PatientConsent[]
  scales        EncounterScale[]

  @@index([workspaceId])
  @@index([patientRegistrationId])
  @@index([doctorId])
}

model EncounterScale {
  id          String   @id @default(cuid())
  encounterId String
  tipo        String // "WOMAC" | "QUICKDASH" | "IKDC"
  valores     Json // Individual question scores / responses
  puntuacion  Float // Overall calculated score
  createdAt   DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
}

model Diagnosis {
  id          String        @id @default(cuid())
  encounterId String
  codigoCie10 String
  descripcion String
  tipo        DiagnosisTipo @default(PRINCIPAL)
  createdAt   DateTime      @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
}

model Medication {
  id                 String   @id @default(cuid())
  nombreGenerico     String
  nombresComerciales String[]
  concentraciones    String[]
  formaFarmaceutica  String
  viaAdministracion  String
  dosisDefaults      Json?
  categoria          String
  isCustom           Boolean  @default(false)
  activo             Boolean  @default(true)
  workspaceId        String?
  createdAt          DateTime @default(now())

  prescriptionItems PrescriptionItem[]

  @@index([nombreGenerico])
  @@index([categoria])
  @@index([workspaceId])
}

model Prescription {
  id          String   @id @default(cuid())
  encounterId String
  pdfUrl      String?
  impresa     Boolean  @default(false)
  createdAt   DateTime @default(now())

  encounter Encounter          @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  items     PrescriptionItem[]

  @@index([encounterId])
}

model PrescriptionItem {
  id                     String  @id @default(cuid())
  prescriptionId         String
  medicationId           String
  concentracion          String
  dosis                  String
  frecuencia             String
  duracion               String
  indicacionesEspeciales String?
  overrideAlerta         Boolean @default(false)

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medication   Medication   @relation(fields: [medicationId], references: [id])

  @@index([prescriptionId])
  @@index([medicationId])
}

model LabOrder {
  id                   String   @id @default(cuid())
  encounterId          String
  estudios             String[]
  indicacionesClinicas String?
  urgente              Boolean  @default(false)
  pdfUrl               String?
  createdAt            DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
}

model LabResult {
  id                    String              @id @default(cuid())
  patientRegistrationId String
  patientRegistration   PatientRegistration @relation(fields: [patientRegistrationId], references: [id], onDelete: Cascade)
  encounterId           String?
  encounter             Encounter?          @relation(fields: [encounterId], references: [id])
  titulo                String
  fecha                 DateTime
  resultado             String              @db.Text
  /// Structured lab values for charting & trend analysis.
  /// Shape: [{ parametro, valor, unidad?, rangoReferencia?, interpretado? }]
  valores               Json?
  notas                 String?
  /// Encrypted (AES-256-GCM). Preferred for new writes. Readers fall back to
  /// `notas` (plaintext) when this is NULL — legacy rows.
  notasCifradas         String?             @db.Text
  createdAt             DateTime            @default(now())

  @@index([patientRegistrationId])
  @@index([encounterId])
}

model ImagingOrder {
  id                   String   @id @default(cuid())
  encounterId          String
  tipoImagen           String
  region               String
  indicacionesClinicas String?
  urgente              Boolean  @default(false)
  pdfUrl               String?
  resultadoUrl         String?
  resultadoNotas       String?
  createdAt            DateTime @default(now())

  encounter Encounter          @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  items     ImagingOrderItem[]

  @@index([encounterId])
}

/// One row per imaging study inside an order. Lets a doctor order several
/// studies at once (e.g. "RX hombro + RX rodilla + Eco rodilla derecha") and
/// have them all show on one printed PDF, mirroring Dr. Pierluissis's
/// handwritten format. `orden` controls display order within the PDF.
model ImagingOrderItem {
  id             String   @id @default(cuid())
  imagingOrderId String
  tipoImagen     String
  region         String
  notas          String?
  orden          Int      @default(0)
  createdAt      DateTime @default(now())

  imagingOrder ImagingOrder @relation(fields: [imagingOrderId], references: [id], onDelete: Cascade)

  @@index([imagingOrderId])
}

model Document {
  id                    String       @id @default(cuid())
  encounterId           String?
  patientRegistrationId String
  tipo                  DocumentTipo
  contenidoHtml         String       @db.Text
  /// Encrypted (AES-256-GCM). Preferred for new writes. Readers fall back to
  /// `contenidoHtml` (plaintext) when this is NULL — legacy rows.
  contenidoHtmlCifrado  String?      @db.Text
  aiDraft               String?      @db.Text
  aiDraftCifrado        String?      @db.Text
  pdfUrl                String?
  firmadoAt             DateTime?
  firmadoPor            String?
  visibleEnPortal       Boolean      @default(false)

  /// Per-consulta override of the doctor's default report preferences.
  /// Populated when the doctor opens the override modal at "Generar informe"
  /// time and picks non-default sections or adds section-specific instructions.
  /// Shape: { seccionesExtra?: string[]; seccionesQuitadas?: string[];
  ///          instrucciones?: Record<ReportSectionKey, string> }.
  /// The doctor's `DoctorReportPreferences` is the source of truth — this
  /// field only stores the delta for that one consulta.
  reportOverride Json?

  referidoANombre       String?
  referidoAEspecialidad String?
  referidoATelefono     String?
  referidoADoctorId     String?
  referidoStatus        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encounter           Encounter?          @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  patientRegistration PatientRegistration @relation(fields: [patientRegistrationId], references: [id], onDelete: Cascade)
  referidoADoctor     Doctor?             @relation("referidosRecibidos", fields: [referidoADoctorId], references: [id], onDelete: SetNull)

  @@index([encounterId])
  @@index([patientRegistrationId])
  @@index([referidoADoctorId])
}

// ---------------------------------------------------------------------------
// FASE 3 — Citas + Facturación
// ---------------------------------------------------------------------------

enum AppointmentType {
  CONSULTA
  SEGUIMIENTO
  EMERGENCIA
  PROCEDIMIENTO
  VIDEOCONSULTA
}

enum AppointmentStatus {
  REQUESTED
  SCHEDULED
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum PaymentMethod {
  EFECTIVO_USD
  EFECTIVO_BS
  TRANSFERENCIA_BS
  ZELLE
  BINANCE_USDT
  PAGOMOVIL
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

model Appointment {
  id                    String  @id @default(cuid())
  workspaceId           String
  patientRegistrationId String?

  titulo          String?
  tipo            AppointmentType   @default(CONSULTA)
  status          AppointmentStatus @default(SCHEDULED)
  fechaHora       DateTime
  duracionMinutos Int               @default(30)
  notas           String?
  serieId         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Audit S9 (2026-07-07): optimistic locking counter. Incremented on every
  /// successful update. Mutations that pass `version` check it against the
  /// current row, and the updateMany returns 0 rows on mismatch → router
  /// throws TRPCError CONFLICT so callers can re-fetch + re-apply. Without
  /// this, two doctors (or a doctor + auto-save debounce) editing the same
  /// encounter concurrently would last-write-wins and silently drop edits.
  /// See docs/AUDIT_BACKLOG.md #12 and server/routers/encounter.ts.
  version   Int      @default(0)

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patientRegistration PatientRegistration? @relation(fields: [patientRegistrationId], references: [id], onDelete: SetNull)
  encounters          Encounter[]
  waitingEntry        WaitingEntry?

  @@index([workspaceId])
  @@index([workspaceId, fechaHora])
  @@index([patientRegistrationId])
  @@index([fechaHora])
  @@index([serieId])
}

model Invoice {
  id                    String  @id @default(cuid())
