# ─── Base de datos ───────────────────────────────────────────────────────────
# Use a connection-pooled URL (PgBouncer) in production if scaling horizontally.
# Required for HIPAA / LOPDP: TLS connection. Append ?sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ajmedics?sslmode=require"

# ─── Cache / Queue ───────────────────────────────────────────────────────────
# Redis is used for: rate limiting, account lockout, medication autocomplete,
# session cache. Require TLS in production (rediss://).
REDIS_URL="rediss://default:PASSWORD@host:6379"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# CRITICAL — this secret signs JWT session tokens. If leaked, an attacker can
# forge arbitrary sessions. Rotate quarterly.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-domain.com"

# ─── Inteligencia Artificial (Anthropic Claude) ──────────────────────────────
# Used for: differential diagnosis assist, drug interaction detection,
# consultation draft generation. NO PHI is sent in prompts — verify in code.
ANTHROPIC_API_KEY=""

# ─── WhatsApp (OpenWA - Self Hosted) ─────────────────────────────────────────
# OpenWA (whatsapp-web.js). Text messages without templates.
OPENWA_URL="http://localhost:2785"
OPENWA_API_KEY="YOUR_SECURE_API_KEY"
OPENWA_SESSION_ID="default"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# In production, configure SPF + DKIM + DMARC on your sending domain.
# DMARC policy: "reject" (strictest). SPF: include only your sending server.
RESEND_API_KEY=""
EMAIL_FROM="AJMedics <no-reply@your-domain.com>"

# ─── Almacenamiento (Cloudflare R2) ──────────────────────────────────────────
# Patient uploads (logos, profile pics). R2 supports SSE-C encryption.
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="ajmedics"

# ─── Seguridad de endpoints cron ─────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=""

# ─── 2FA / TOTP ──────────────────────────────────────────────────────────────
# Issuer name shown in authenticator apps (Google Authenticator, Authy, 1Password)
TOTP_ISSUER="MedSysVE"

# ─── Rate limiting (Redis-backed sliding window) ─────────────────────────────
# These are the defaults — adjust per environment in the proxy.ts / auth.ts files.
# RL_LOGIN_MAX=10                  # doctor/staff login attempts per window
# RL_LOGIN_WINDOW_SEC=300          # 5 minutes
# RL_PORTAL_LOGIN_MAX=5
# RL_PORTAL_LOGIN_WINDOW_SEC=300
# RL_REGISTER_MAX=3
# RL_REGISTER_WINDOW_SEC=3600

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error
# In production, set to "info" — debug logs may include routing details.
LOG_LEVEL="info"

# ─── Feature flags ───────────────────────────────────────────────────────────
# Toggle HIPAA-style hardening in development vs production.
# NODE_ENV is set automatically by Next.js.
# DISABLE_RATE_LIMIT=true          # ONLY for local dev. Never in prod.

# ─── Audit & compliance ──────────────────────────────────────────────────────
# Where to ship audit events (Coolify collects stdout by default into Loki).
# For external SIEM: AUDIT_WEBHOOK_URL=https://siem.your-domain.com/ingest
# AUDIT_WEBHOOK_URL=""
# AUDIT_WEBHOOK_SECRET="generate-with-openssl-rand-hex-32"

# ─── Encryption (field-level encryption for PHI) ────────────────────────────
# Generate: openssl rand -base64 32 (32 bytes = 256-bit AES key)
# Used by lib/field-crypto.ts for PHI cipher (AES-256-GCM) and HMAC index.
# DO NOT use for password hashing (that's bcrypt's job).
FIELD_ENCRYPTION_KEY=""
FIELD_HMAC_KEY=""

# ─── Encounter signing key (separate from encryption, audit #7 follow-up) ────
# Used by lib/encounter-signing.ts as HMAC secret for signed encounters.
# Separation from FIELD_ENCRYPTION_KEY means rotating the encryption key
# (for PHI) does NOT invalidate existing encounter signatures.
#
# On first deploy: set FIELD_SIGN_KEY to the same value as FIELD_ENCRYPTION_KEY.
# All existing signed encounters remain verifiable.
#
# Generate: openssl rand -base64 32
FIELD_SIGN_KEY=""

# ─── Monitoring / Observability (Google Cloud Platform) ──────────────────────
# The Google Cloud Project ID.
GOOGLE_CLOUD_PROJECT="medsysve-gcp"